# Secrets: use Doppler in CI/deploy; for local dev copy this to .env
# See docs/doppler-and-env.md for Doppler project: nevermined-hackathon-sabi

# Nevermined (required for A2A payments)
# Sandbox: get key from https://nevermined.app → API Keys. Production: use prod key and NVM_ENVIRONMENT=live.
NVM_API_KEY=sandbox:your-api-key
NVM_ENVIRONMENT=testing
NVM_AGENT_ID=
NVM_PLAN_ID=

# Backend (Cloudflare Workers) -- set via `wrangler secret put` for production
# Webapp (Next.js / Vercel)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Seller registration (run scripts/register-agent.ts once; then set NVM_AGENT_ID, NVM_PLAN_ID)
# Your wallet address for receiving payments (e.g. Base Sepolia for sandbox)
BUILDER_ADDRESS=

# USDC contract (sandbox: Base Sepolia)
# https://nevermined.ai/docs/integrate/quickstart/5-minute-setup
NVM_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# App / hosting (set when deploying)
PORT=3000
# Public base URL of seller — use your Cloudflare Workers deployment (e.g. https://your-app.workers.dev). No trailing slash. Endpoint is APP_URL/query.
APP_URL=

# Optional: LangChain / evals, Exa, Apify, AWS, Mindra (add as you integrate)
# OPENAI_API_KEY=
# EXA_API_KEY=
# APIFY_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

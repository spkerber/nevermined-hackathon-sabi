{
  "name": "sabi",
  "version": "0.1.0",
  "description": "Sabi SDK & CLI — verification-as-a-service powered by Nevermined",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sabi": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/cli/index.ts --format esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}

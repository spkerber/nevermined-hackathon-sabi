import Foundation

enum Secrets {
  // REQUIRED: Get your key at https://aistudio.google.com/apikey
  static let geminiAPIKey = "YOUR_GEMINI_API_KEY"

  // REQUIRED: Supabase project config (from supabase.com dashboard)
  static let supabaseURL = "https://YOUR_PROJECT.supabase.co"
  static let supabaseAnonKey = "YOUR_SUPABASE_ANON_KEY"

  // REQUIRED: Cloudflare Worker URL
  static let workerURL = "https://ray-banned.YOUR_SUBDOMAIN.workers.dev"

  // OPTIONAL: WebRTC signaling server URL
  static let webrtcSignalingURL = "ws://YOUR_MAC_IP:8080"
}

{
  "name": "nevermined-hackathon-sabi",
  "version": "0.1.0",
  "private": true,
  "description": "Visual Verification as a Service — Nevermined A2A buyers/sellers agents",
  "type": "module",
  "scripts": {
    "register-agent": "tsx scripts/register-agent.ts",
    "seller": "tsx src/seller/server.ts",

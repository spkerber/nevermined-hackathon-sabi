  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "qs": ">=6.14.2",
    "@tootallnate/once": ">=3.0.1",
    "langsmith": ">=0.4.6"
